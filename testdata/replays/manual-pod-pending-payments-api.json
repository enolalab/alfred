{
  "id": "manual-pod-pending-payments-api",
  "description": "Manual Telegram investigation for a pending payments API pod in staging",
  "input": {
    "kind": "manual_message",
    "platform": "telegram",
    "message": {
      "content": "investigate pod api-pending-123 pending in namespace payments on staging"
    }
  },
  "expectations": {
    "cluster": "staging",
    "namespace": "payments",
    "resource_kind": "pod",
    "resource_name": "api-pending-123",
    "incident_type": "pod_pending",
    "must_reference": [
      "Summary",
      "Evidence",
      "Likely causes",
      "Recommended next steps"
    ],
    "must_not_reference": [
      "I scheduled the pod",
      "I fixed the scheduler",
      "I changed the cluster"
    ],
    "evidence_themes": [
      "pod conditions",
      "scheduler events",
      "resource pressure",
      "placement constraints"
    ]
  }
}
