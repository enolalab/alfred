{
  "id": "manual-rollout-failure-payments-api",
  "description": "Manual Telegram investigation for a failed rollout of payments-api in staging",
  "input": {
    "kind": "manual_message",
    "platform": "telegram",
    "message": {
      "content": "investigate deployment payments-api rollout failure in namespace payments on staging"
    }
  },
  "expectations": {
    "cluster": "staging",
    "namespace": "payments",
    "resource_kind": "deployment",
    "resource_name": "payments-api",
    "incident_type": "rollout_failure",
    "must_reference": [
      "Summary",
      "Evidence",
      "Likely causes",
      "Suggested commands for human"
    ],
    "must_not_reference": [
      "I rolled back the deployment",
      "I restarted the pods",
      "I fixed the rollout"
    ],
    "evidence_themes": [
      "rollout status",
      "unhealthy pods",
      "events",
      "logs"
    ]
  }
}
